[case testReSearchGroupValidation]
import re
m = re.search(r"(?P<year>\d{4})-(?P<month>\d{2})-(?P<day>\d{2})", "2025-01-15")
if m:
    m.group("year")
    m.group("month")
    m.group("day")
    m.group("hour")  # E: Regex pattern has no group named "hour"; pattern has groups: ['day', 'month', 'year']
    m.group(4)  # E: Regex group index 4 is out of range (pattern has 3 groups)
[builtins fixtures/tuple.pyi]

[case testReFullmatchGroupValidation]
import re
m = re.fullmatch(r"(?P<proto>\w+)://(?P<host>[^/]+)", "https://example.com")
if m:
    m.group("proto")
    m.group("host")
    m.group("path")  # E: Regex pattern has no group named "path"; pattern has groups: ['host', 'proto']
[builtins fixtures/tuple.pyi]

[case testReMatchGetitemValidation]
import re
m = re.match(r"(?P<name>\w+)", "alice")
if m:
    m[0]
    m[1]
    m["name"]
    m[2]  # E: Regex group index 2 is out of range (pattern has 1 groups)
    m["missing"]  # E: Regex pattern has no group named "missing"; pattern has groups: ['name']
[builtins fixtures/tuple.pyi]

