[case testReSubOctalEscapesAreNotGroupRefs]
import re

re.sub(r"(a)", r"\07", "a")
re.sub(r"(a)", r"\0", "a")
re.sub(r"(a)", r"\011", "a")
re.sub(r"(a)", r"\11", "a")  # E: Replacement references group 11, but pattern only has 1 group(s)
[builtins fixtures/tuple.pyi]

[case testReIncrementalPatternUpdate]
import m

[file m.py]
import re
pat = re.compile(r"(\w+)")
pat.sub(r"\2", "hello")

[out1]
tmp/m.py:3: error: Replacement references group 2, but pattern only has 1 group(s)

[file m.py.2]
import re
pat = re.compile(r"(\w+)(\w+)")
pat.sub(r"\2", "hello")

[rechecked m]

[builtins fixtures/tuple.pyi]
