[case testReMatchGroupInvalidStringName]
import re
m = re.match(r"(?P<name>\w+) (?P<age>\d+)", "alice 30")
if m:
    m.group("name")
    m.group("age")
    m.group("nonexist")  # E: Regex pattern has no group named "nonexist"; pattern has groups: ['age', 'name']
[builtins fixtures/tuple.pyi]

[case testReMatchGroupInvalidIndex]
import re
m = re.match(r"(\w+) (\d+)", "alice 30")
if m:
    m.group(1)
    m.group(2)
    m.group(3)  # E: Regex group index 3 is out of range (pattern has 2 groups)
[builtins fixtures/tuple.pyi]

[case testReMatchGroupZeroAlwaysValid]
