[case testRePatternSubInFunctionTracksPattern]
import re

def f() -> None:
    pat = re.compile(r"(\w+)")
    pat.sub(r"\2", "hello")  # E: Replacement references group 2, but pattern only has 1 group(s)

f()
[builtins fixtures/tuple.pyi]

[case testReMatchFromPatternMatchGroupValidation]
import re

pat = re.compile(r"(?P<name>\w+) (?P<age>\d+)")
m = pat.match("alice 30")
if m:
    m.group("name")
    m.group("naem")  # E: Regex pattern has no group named "naem"; pattern has groups: ['age', 'name']
    m.group(3)  # E: Regex group index 3 is out of range (pattern has 2 groups)
[builtins fixtures/tuple.pyi]

[case testReMatchFromInlineCompileMatchGroupValidation]
import re

m = re.compile(r"(?P<word>\w+)").match("hello")
if m:
    m.group("word")
    m.group("missing")  # E: Regex pattern has no group named "missing"; pattern has groups: ['word']
[builtins fixtures/tuple.pyi]

