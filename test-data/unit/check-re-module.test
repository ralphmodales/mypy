[case testReFlagsVerboseAffectValidation]
import re

re.compile(r"#)")  # E: Invalid regex pattern: unbalanced parenthesis at position 1
re.compile(r"#)", re.VERBOSE)
re.compile(r"#)", flags=re.VERBOSE)
re.match(r"#)", "x", re.VERBOSE)
[builtins fixtures/tuple.pyi]

