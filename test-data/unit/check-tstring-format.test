[case testTStringFormatValidIntSpec]
# flags: --python-version 3.14
x: int
reveal_type(t"{x:d}")  # N: Revealed type is "string.templatelib.Template"
t"{x:b}"
t"{x:o}"
t"{x:x}"
t"{x:X}"
t"{x:n}"
t"{x:.4f}"
t"{x:e}"
t"{x:%}"
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatStrIncompatibleWithIntSpec]
# flags: --python-version 3.14
x: str
t"{x:d}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int")
t"{x:b}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int")
t"{x:o}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int")
t"{x:x}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int")
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatStrIncompatibleWithFloatSpec]
# flags: --python-version 3.14
x: str
t"{x:f}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int | float")
t"{x:e}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int | float")
t"{x:g}"  # E: Incompatible types in string interpolation (expression has type "str", placeholder has type "int | float")
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatFloatIncompatibleWithIntSpec]
# flags: --python-version 3.14
x: float
t"{x:d}"  # E: Incompatible types in string interpolation (expression has type "float", placeholder has type "int")
t"{x:b}"  # E: Incompatible types in string interpolation (expression has type "float", placeholder has type "int")
t"{x:x}"  # E: Incompatible types in string interpolation (expression has type "float", placeholder has type "int")
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatConversionMakesValueStr]
# flags: --python-version 3.14
x: int
t"{x!s}"
t"{x!r}"
t"{x!a}"
t"{x!s:>10}"
t"{x!r:>10}"
t"{x!a:>10}"
t"{x!s:^5}"
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatStrAcceptsAnyValue]
# flags: --python-version 3.14
x: int
y: float
t"{x:s}"
t"{y:s}"
t"{x}"
t"{y}"
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatNestedSpecAllInt]
# flags: --python-version 3.14
value: float
width: int
precision: int
t"result: {value:{width}.{precision}}"
t"{value:{width}}"
t"{value:.{precision}f}"
[builtins fixtures/f_string.pyi]
[typing fixtures/typing-medium.pyi]

[case testTStringFormatNestedSpecNonIntWidth]
