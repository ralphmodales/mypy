[case testIdentityNarrowingAnyNewTypeWrappingAnyEnumFallbackPreserves]
import enum
from typing import Any, NewType

class Status(enum.Enum):
    A = enum.auto()
    B = enum.auto()

StatusId = NewType('StatusId', Status)
CURRENT: StatusId = StatusId(Status.A)

def check(value: Any) -> None:
    if value is CURRENT:
        reveal_type(CURRENT)  # N: Revealed type is "__main__.StatusId"
        reveal_type(value)  # N: Revealed type is "__main__.Status"
[builtins fixtures/primitives.pyi]

