[case testIdentityNarrowingWithSentinelInDictLookup]
import enum
from typing import Any

class Sentinel(enum.Enum):
    MISSING = enum.auto()
MISSING: Sentinel = Sentinel.MISSING

def get_value(value: Any) -> None:
    if value is MISSING:
        reveal_type(MISSING)  # N: Revealed type is "Literal[__main__.Sentinel.MISSING]"
        reveal_type(value)  # N: Revealed type is "Literal[__main__.Sentinel.MISSING]"
[builtins fixtures/primitives.pyi]

