class Kind(enum.Enum):
    A = 1
    B = 2

def check(x: Any, k: Literal[Kind.A]) -> None:
    if x is k:
        reveal_type(k)  # N: Revealed type is "Literal[__main__.Kind.A]"
        reveal_type(x)  # N: Revealed type is "Literal[__main__.Kind.A]"
[builtins fixtures/primitives.pyi]

[case testIdentityNarrowingAnyIsNotWithUnion]
from typing import Any, Optional

def check(x: Any, y: Optional[str]) -> None:
    if x is not y:
        reveal_type(y)  # N: Revealed type is "builtins.str | None"
    else:
        reveal_type(y)  # N: Revealed type is "builtins.str | None"
        reveal_type(x)  # N: Revealed type is "builtins.str | None"
[builtins fixtures/primitives.pyi]

