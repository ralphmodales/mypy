[case testIdentityNarrowingAnyPreservesFunctionParameter]
from typing import Any

def sentinel_check(sentinel: str, item: Any) -> None:
    if item is sentinel:
        reveal_type(sentinel)  # N: Revealed type is "builtins.str"
        reveal_type(item)  # N: Revealed type is "builtins.str"
    reveal_type(sentinel)  # N: Revealed type is "builtins.str"
[builtins fixtures/primitives.pyi]

[case testIdentityNarrowingAnyChainedIdentity]
from typing import Any

def f(x: Any, y: str, z: str) -> None:
    if x is y is z:
        reveal_type(x)  # N: Revealed type is "builtins.str"
        reveal_type(y)  # N: Revealed type is "builtins.str"
        reveal_type(z)  # N: Revealed type is "builtins.str"
