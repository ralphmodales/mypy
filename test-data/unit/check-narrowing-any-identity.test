[case testIdentityNarrowingAnyIgnoresConcreteListWithAnyArg]
from typing import Any, List

def f(x: str, y: List[Any]) -> None:
    if x is y:
        # list[Any] is a concrete container; str vs list[Any] does not overlap
        # so narrowing collapses to unreachable rather than widening x.
        reveal_type(x)  # N: Revealed type is "builtins.str"
[builtins fixtures/list.pyi]

