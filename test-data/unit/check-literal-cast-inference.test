[case testLiteralListLiteralInferredFromNegativeIntLiteral]
# flags: --warn-redundant-casts
from typing import Literal, TypeVar
from typing import Mapping, Sequence
T = TypeVar("T")
Code = Literal[-1, 0, 1]
def function(seq1: Mapping[T, str], seq2: Sequence[T]) -> T: ...
codes: Mapping[Code, str] = {-1: "neg", 0: "zero", 1: "pos"}
result = function(codes, [-1, 0])
reveal_type(result)  # N: Revealed type is "Literal[-1] | Literal[0] | Literal[1]"
[builtins fixtures/dict-full.pyi]

[case testLiteralListLiteralInferredFromConditional]
# flags: --warn-redundant-casts
from typing import Literal, TypeVar
from typing import Mapping, Sequence
T = TypeVar("T")
Fruit = Literal["apple", "orange"]
def function(seq1: Mapping[T, str], seq2: Sequence[T]) -> T: ...
all_fruits: Mapping[Fruit, str] = {"apple": "a", "orange": "o"}
flag = True
result = function(all_fruits, ["apple" if flag else "orange"])
