[case testLiteralListInferenceWithThreeArgs]
# flags: --warn-redundant-casts
from typing import Literal, TypeVar
from typing import Mapping, Sequence
T = TypeVar("T")
Tag = Literal["a", "b", "c"]
def function(m: Mapping[T, int], s: Sequence[T], extra: T) -> T: ...
tags: Mapping[Tag, int] = {"a": 1, "b": 2, "c": 3}
result = function(tags, ["a", "b"], "c")
reveal_type(result)  # N: Revealed type is "Literal['a'] | Literal['b'] | Literal['c']"
[builtins fixtures/dict.pyi]

[case testLiteralListLiteralInferredViaContextOnlyTwoArgs]
# flags: --warn-redundant-casts
from typing import Literal, TypeVar
from typing import Sequence
T = TypeVar("T")
Tag = Literal["red", "green", "blue"]
def function(seq: Sequence[T], default: T) -> T: ...
default: Tag = "blue"
result = function(["red"], default)
reveal_type(result)  # N: Revealed type is "Literal['red'] | Literal['green'] | Literal['blue']"
[builtins fixtures/list.pyi]

