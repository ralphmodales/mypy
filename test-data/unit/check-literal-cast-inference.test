[case testCollectionDisplayInferenceWithConcreteNonLiteralPin]
from typing import TypeVar, Sequence
T = TypeVar("T")
def function(x: T, seq: Sequence[T]) -> T: ...
n: int = 1
reveal_type(function(n, [1, 2]))  # N: Revealed type is "builtins.int"
reveal_type(function(n, ["a"]))  # N: Revealed type is "builtins.int" \
                                 # E: List item 0 has incompatible type "str"; expected "int"
[builtins fixtures/list.pyi]

[case testLiteralDictValuesInferredFromSharedTypeVar]
