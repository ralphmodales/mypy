[case testLiteralCastNotRedundantStringUnion]
# flags: --warn-redundant-casts
from typing import Literal, cast
Fruit = Literal["apple", "orange"]
x = cast(Fruit, "apple")
reveal_type(x)  # N: Revealed type is "Literal['apple'] | Literal['orange']"
[builtins fixtures/tuple.pyi]

[case testLiteralCastNotRedundantSingleString]
# flags: --warn-redundant-casts
from typing import Literal, cast
x = cast(Literal["a"], "a")
reveal_type(x)  # N: Revealed type is "Literal['a']"
[builtins fixtures/tuple.pyi]

[case testLiteralCastNotRedundantIntUnion]
# flags: --warn-redundant-casts
from typing import Literal, cast
Mode = Literal[1, 2, 3]
x = cast(Mode, 1)
reveal_type(x)  # N: Revealed type is "Literal[1] | Literal[2] | Literal[3]"
[builtins fixtures/tuple.pyi]

[case testLiteralCastNotRedundantBoolUnion]
# flags: --warn-redundant-casts
from typing import Literal, cast
Flag = Literal[True, False]
x = cast(Flag, True)
reveal_type(x)  # N: Revealed type is "Literal[True] | Literal[False]"
[builtins fixtures/tuple.pyi]

[case testLiteralCastInFunctionCallList]
# flags: --warn-redundant-casts
from typing import Literal, TypeVar, cast
from typing import Mapping, Sequence
T = TypeVar("T")
Fruit = Literal["apple", "orange"]
def function(seq1: Mapping[T, str], seq2: Sequence[T]) -> T: ...
all_fruits: Mapping[Fruit, str] = {"apple": "a", "orange": "o"}
result = function(all_fruits, [cast(Fruit, "apple")])
reveal_type(result)  # N: Revealed type is "Literal['apple'] | Literal['orange']"
[builtins fixtures/dict.pyi]

