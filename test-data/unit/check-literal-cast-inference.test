def function(m: Mapping[T, str], d: Dict[str, T]) -> T: ...
tags: Mapping[Tag, str] = {"x": "ex", "y": "why"}
result = function(tags, {"a": "x", "b": "y"})
reveal_type(result)  # N: Revealed type is "Literal['x'] | Literal['y']"
[builtins fixtures/dict.pyi]

