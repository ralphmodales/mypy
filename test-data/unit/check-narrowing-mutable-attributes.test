[case testNarrowingMutableAttributePreservedForImmutableReceiver]
# flags: --strict-equality --warn-unreachable --python-version 3.10
class C:
    x: int | None
    def reset(self) -> None: ...

def func(c: C, s: str) -> None:
    if c.x is None:
        return
    reveal_type(c.x)  # N: Revealed type is "builtins.int"
    s.split(",")
    reveal_type(c.x)  # N: Revealed type is "builtins.int"
    t = (1, 2)
    t.__contains__(1)
    reveal_type(c.x)  # N: Revealed type is "builtins.int"
    c.reset()
    reveal_type(c.x)  # N: Revealed type is "builtins.int | None"
[builtins fixtures/primitives.pyi]

