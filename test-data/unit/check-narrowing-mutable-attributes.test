[case testNarrowingMutableAttributePreservedAcrossChainedCallSegments]
# flags: --strict-equality --warn-unreachable --python-version 3.10
class Inner:
    v: int | None
    def go(self) -> "Inner": ...

class Outer:
    inner: Inner
    other: int | None

def func(o: Outer) -> None:
    if o.other is None:
        return
    if o.inner.v is None:
        return
    reveal_type(o.other)    # N: Revealed type is "builtins.int"
    reveal_type(o.inner.v)  # N: Revealed type is "builtins.int"
    o.inner.go().go()
    reveal_type(o.other)    # N: Revealed type is "builtins.int"
    reveal_type(o.inner.v)  # N: Revealed type is "builtins.int | None"
