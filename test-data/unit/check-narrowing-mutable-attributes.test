[case testNarrowingFinalAttributePreservedInheritedFromBase]
# flags: --strict-equality --warn-unreachable --python-version 3.10
from typing import Final

class Base:
    final_x: Final[int | None]
    def __init__(self, x: int | None) -> None:
        self.final_x = x

class Derived(Base):
    y: int | None
    def __init__(self, x: int | None) -> None:
        super().__init__(x)
        self.y = x
    def mutate(self) -> None: ...

def func(d: Derived) -> None:
    if d.final_x is None:
        return
    if d.y is None:
        return
    reveal_type(d.final_x)  # N: Revealed type is "builtins.int"
    reveal_type(d.y)        # N: Revealed type is "builtins.int"
    d.mutate()
    reveal_type(d.final_x)  # N: Revealed type is "builtins.int"
    reveal_type(d.y)        # N: Revealed type is "builtins.int | None"
[builtins fixtures/primitives.pyi]
[typing fixtures/typing-medium.pyi]

