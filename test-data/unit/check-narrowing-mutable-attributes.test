[case testNarrowingMutableAttributeAfterMethodCall]
# flags: --strict-equality --warn-unreachable --python-version 3.10
from enum import Enum
from dataclasses import dataclass

class E(Enum):
    A = 1
    B = 2

@dataclass
class D:
    e: E
    def set_e(self, e: E) -> None:
        self.e = e

def func(d: D, e: E) -> None:
    if d.e == E.A:
        return
    reveal_type(d.e)  # N: Revealed type is "Literal[__main__.E.B]"
    d.set_e(e)
    reveal_type(d.e)  # N: Revealed type is "__main__.E"
    if d.e == E.A:
        return
    reveal_type(d.e)  # N: Revealed type is "Literal[__main__.E.B]"
[builtins fixtures/primitives.pyi]

