[case testStructNamedInstance]
from struct import Struct
buf: bytearray
s = Struct("ii")
reveal_type(s.unpack(b""))  # N: Revealed type is "tuple[builtins.int, builtins.int]"
reveal_type(s.unpack_from(b""))  # N: Revealed type is "tuple[builtins.int, builtins.int]"
reveal_type(s.iter_unpack(b""))  # N: Revealed type is "typing.Iterator[tuple[builtins.int, builtins.int]]"
s.pack(1, 2)
s.pack_into(buf, 0, 1, 2)
s.pack("bad", 2)  # E: Argument 1 to "Struct.pack" has incompatible type "str"; expected "int" (for format char "i")
s.pack_into(buf, 0, 1)  # E: Wrong number of values for format "ii": expected 2, got 1
[builtins fixtures/tuple.pyi]

