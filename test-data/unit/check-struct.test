reveal_type(struct.unpack("0s", b""))  # N: Revealed type is "tuple[builtins.bytes]"
reveal_type(struct.unpack("255s", b""))  # N: Revealed type is "tuple[builtins.bytes]"
reveal_type(struct.unpack("5p", b""))  # N: Revealed type is "tuple[builtins.bytes]"
reveal_type(struct.unpack("0c", b""))  # N: Revealed type is "tuple[()]"
[builtins fixtures/tuple.pyi]

[case testStructUnpackMixedLargerFormat]
