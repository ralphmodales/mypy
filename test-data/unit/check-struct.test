[case testStructPackLiteralUnionAcceptedByOneMember]
from typing import Literal
import struct
def f(fmt: Literal["i", "s"]) -> None:
    struct.pack(fmt, 1)
    struct.pack(fmt, b"x")
    struct.pack(fmt, 1.5)  # E: Argument 1 to "struct.pack" has incompatible type "float"; expected "int" (for format char "i")
[builtins fixtures/tuple.pyi]
[typing fixtures/typing-medium.pyi]

[case testStructPackRichFormats]
import struct
buf: bytearray
struct.pack(">ii", 1, 2)
struct.pack("i i", 1, 2)
struct.pack("3i", 1, 2, 3)
struct.pack("2xi", 1)
struct.pack("<2h2i", 1, 2, 3, 4)
struct.pack("5p", b"hi")
struct.pack(b">ii", 1, 2)
struct.pack_into(">ii", buf, 0, 1, 2)
struct.pack_into("i i", buf, 0, 1, 2)
struct.pack_into("3i", buf, 0, 1, 2, 3)
struct.pack_into("2xi", buf, 0, 1)
struct.pack_into(b">ii", buf, 0, 1, 2)
struct.pack(">ii", 1)  # E: Wrong number of values for format ">ii": expected 2, got 1
struct.pack("3i", 1, 2)  # E: Wrong number of values for format "3i": expected 3, got 2
struct.pack("2xi", "bad")  # E: Argument 1 to "struct.pack" has incompatible type "str"; expected "int" (for format char "i")
struct.pack("i i", 1, "bad")  # E: Argument 2 to "struct.pack" has incompatible type "str"; expected "int" (for format char "i")
struct.pack(b">ii", 1, "bad")  # E: Argument 2 to "struct.pack" has incompatible type "str"; expected "int" (for format char "i")
struct.pack_into("3i", buf, 0, 1, 2)  # E: Wrong number of values for format "3i": expected 3, got 2
struct.pack_into("2xi", buf, 0, "bad")  # E: Argument 1 to "struct.pack_into" has incompatible type "str"; expected "int" (for format char "i")
from struct import Struct
Struct(">ii").pack(1, 2)
Struct("i i").pack(1, 2)
Struct("3i").pack(1, 2, 3)
Struct("2xi").pack(1)
Struct(b">ii").pack(1, 2)
Struct(">ii").pack_into(buf, 0, 1, 2)
Struct("3i").pack_into(buf, 0, 1, 2, 3)
Struct(">ii").pack(1)  # E: Wrong number of values for format ">ii": expected 2, got 1
Struct("3i").pack(1, 2)  # E: Wrong number of values for format "3i": expected 3, got 2
Struct("2xi").pack("bad")  # E: Argument 1 to "Struct.pack" has incompatible type "str"; expected "int" (for format char "i")
Struct("i i").pack(1, "bad")  # E: Argument 2 to "Struct.pack" has incompatible type "str"; expected "int" (for format char "i")
Struct(">ii").pack_into(buf, 0, 1)  # E: Wrong number of values for format ">ii": expected 2, got 1
Struct("2xi").pack_into(buf, 0, "bad")  # E: Argument 1 to "Struct.pack_into" has incompatible type "str"; expected "int" (for format char "i")
[builtins fixtures/tuple.pyi]

