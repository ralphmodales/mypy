[case testStructPackStarArgsPartialCheck]
import struct
args: tuple[int, ...]
struct.pack("ii", 1, *args)
struct.pack("if", 1, *args)
struct.pack("if", "bad", *args)  # E: Argument 1 to "struct.pack" has incompatible type "str"; expected "int" (for format char "i")
struct.pack("if", 1.5, *args)  # E: Argument 1 to "struct.pack" has incompatible type "float"; expected "int" (for format char "i")
from struct import Struct
Struct("if").pack("bad", *args)  # E: Argument 1 to "Struct.pack" has incompatible type "str"; expected "int" (for format char "i")
[builtins fixtures/tuple.pyi]

[case testStructCalcsizeLiteralInt]
from typing import Final, Literal
import struct
reveal_type(struct.calcsize("<ii"))  # N: Revealed type is "Literal[8]"
reveal_type(struct.calcsize(">3i"))  # N: Revealed type is "Literal[12]"
reveal_type(struct.calcsize("=ff"))  # N: Revealed type is "Literal[8]"
reveal_type(struct.calcsize("<2xi"))  # N: Revealed type is "Literal[6]"
reveal_type(struct.calcsize("<5s"))  # N: Revealed type is "Literal[5]"
reveal_type(struct.calcsize("<5p"))  # N: Revealed type is "Literal[5]"
reveal_type(struct.calcsize("<h H q Q"))  # N: Revealed type is "Literal[20]"
reveal_type(struct.calcsize(b"<ii"))  # N: Revealed type is "Literal[8]"
FMT_CS: Final = "<ii"
reveal_type(struct.calcsize(FMT_CS))  # N: Revealed type is "Literal[8]"
def f(fmt: Literal["<ii", "<4s"]) -> None:
    reveal_type(struct.calcsize(fmt))  # N: Revealed type is "Literal[8] | Literal[4]"
[builtins fixtures/tuple.pyi]
[typing fixtures/typing-medium.pyi]

