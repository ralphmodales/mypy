reveal_type(struct.unpack("?x?", b""))  # N: Revealed type is "tuple[builtins.bool, builtins.bool]"
reveal_type(struct.unpack("fd4x", b""))  # N: Revealed type is "tuple[builtins.float, builtins.float]"
reveal_type(struct.unpack("2i4x2h", b""))  # N: Revealed type is "tuple[builtins.int, builtins.int, builtins.int, builtins.int]"
reveal_type(struct.unpack("iP", b""))  # N: Revealed type is "tuple[builtins.int, builtins.int]"
[builtins fixtures/tuple.pyi]

