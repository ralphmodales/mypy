[case testStructUnpackBasicFormats]
import struct
reveal_type(struct.unpack("i", b""))  # N: Revealed type is "tuple[builtins.int]"
reveal_type(struct.unpack("ii", b""))  # N: Revealed type is "tuple[builtins.int, builtins.int]"
reveal_type(struct.unpack(">hhb", b""))  # N: Revealed type is "tuple[builtins.int, builtins.int, builtins.int]"
reveal_type(struct.unpack("f", b""))  # N: Revealed type is "tuple[builtins.float]"
reveal_type(struct.unpack("fd", b""))  # N: Revealed type is "tuple[builtins.float, builtins.float]"
reveal_type(struct.unpack("?", b""))  # N: Revealed type is "tuple[builtins.bool]"
reveal_type(struct.unpack("c", b""))  # N: Revealed type is "tuple[builtins.bytes]"
[builtins fixtures/tuple.pyi]

[case testStructUnpackRepeatCount]
import struct
reveal_type(struct.unpack("3i", b""))  # N: Revealed type is "tuple[builtins.int, builtins.int, builtins.int]"
reveal_type(struct.unpack("2c", b""))  # N: Revealed type is "tuple[builtins.bytes, builtins.bytes]"
reveal_type(struct.unpack("5c", b""))  # N: Revealed type is "tuple[builtins.bytes, builtins.bytes, builtins.bytes, builtins.bytes, builtins.bytes]"
[builtins fixtures/tuple.pyi]

[case testStructUnpackPadAndPrefix]
import struct
reveal_type(struct.unpack("2xi", b""))  # N: Revealed type is "tuple[builtins.int]"
reveal_type(struct.unpack("@i", b""))  # N: Revealed type is "tuple[builtins.int]"
reveal_type(struct.unpack("=i", b""))  # N: Revealed type is "tuple[builtins.int]"
reveal_type(struct.unpack("<bhl", b""))  # N: Revealed type is "tuple[builtins.int, builtins.int, builtins.int]"
reveal_type(struct.unpack("!L", b""))  # N: Revealed type is "tuple[builtins.int]"
[builtins fixtures/tuple.pyi]

