[case testConditionalTypedDictRequiredNotRequiredReadOnly]
# flags: --python-version 3.12
import sys
from typing import TypedDict
from typing_extensions import Required, NotRequired, ReadOnly

class D(TypedDict):
    x: int
    if sys.version_info >= (3, 12):
        y: NotRequired[str]
        z: ReadOnly[int]

d1: D = {"x": 1, "z": 5}
d2: D = {"x": 1, "y": "hi", "z": 5}
d2["z"] = 10  # E: ReadOnly TypedDict key "z" TypedDict is mutated

class D2(TypedDict, total=False):
    x: int
    if sys.version_info >= (3, 12):
        y: Required[str]

d3: D2 = {"x": 1, "y": "hi"}
d4: D2 = {"x": 1}  # E: Missing key "y" for TypedDict "D2"
[builtins fixtures/dict.pyi]
[typing fixtures/typing-typeddict.pyi]

