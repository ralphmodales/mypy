[case testConditionalTypedDictSysVersionPresent]
# flags: --python-version 3.12
import sys
from typing import TypedDict

class D(TypedDict):
    x: int
    if sys.version_info >= (3, 12):
        y: str

d1: D = {"x": 1, "y": "hello"}
d2: D = {"x": 1}  # E: Missing key "y" for TypedDict "D"
d3: D = {"x": 1, "y": "hi", "z": 2}  # E: Extra key "z" for TypedDict "D"
[builtins fixtures/dict.pyi]
[typing fixtures/typing-typeddict.pyi]

