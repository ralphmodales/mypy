[case testConditionalNamedTupleElifChain312]
# flags: --python-version 3.12
import sys
from typing import NamedTuple

class N(NamedTuple):
    x: int
    if sys.version_info >= (3, 13):
        a: str
    elif sys.version_info >= (3, 12):
        b: bool
    elif sys.version_info >= (3, 11):
        c: int
    else:
        d: int

n = N(1, True)
reveal_type(n)  # N: Revealed type is "tuple[builtins.int, builtins.bool, fallback=__main__.N]"
n.a  # E: "N" has no attribute "a"
n.c  # E: "N" has no attribute "c"
[builtins fixtures/tuple.pyi]

