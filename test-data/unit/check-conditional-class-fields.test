[case testConditionalNamedTupleSysVersionPresent]
# flags: --python-version 3.12
import sys
from typing import NamedTuple

class N(NamedTuple):
    x: int
    if sys.version_info >= (3, 12):
        y: str

n = N(1, "hello")
reveal_type(n)  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.N]"
reveal_type(n._replace(y="world"))  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.N]"
reveal_type(n.y)  # N: Revealed type is "builtins.str"
N(1)  # E: Missing positional argument "y" in call to "N"
[builtins fixtures/tuple.pyi]

[case testConditionalNamedTupleSysVersionAbsent]
# flags: --python-version 3.11
import sys
from typing import NamedTuple

class N(NamedTuple):
    x: int
    if sys.version_info >= (3, 12):
        y: str

n = N(1)
reveal_type(n)  # N: Revealed type is "tuple[builtins.int, fallback=__main__.N]"
reveal_type(n._replace())  # N: Revealed type is "tuple[builtins.int, fallback=__main__.N]"
n.y  # E: "N" has no attribute "y"
N(1, "extra")  # E: Too many arguments for "N"
[builtins fixtures/tuple.pyi]

[case testConditionalNamedTupleNonDefaultFollowsDefault]
# flags: --python-version 3.12
import sys
from typing import NamedTuple

class N(NamedTuple):
    x: int
    if sys.version_info >= (3, 12):
        y: str = "hello"
    z: int  # E: Non-default NamedTuple fields cannot follow default fields

class OK(NamedTuple):
    x: int
    if sys.version_info >= (3, 12):
        y: str = "world"

ok = OK(1)
reveal_type(ok)  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.OK]"
[builtins fixtures/tuple.pyi]

[case testConditionalNamedTupleStaticTruthForms]
# flags: --always-false STATIC_FALSE
from typing import NamedTuple, TYPE_CHECKING

STATIC_FALSE = True

class A(NamedTuple):
    x: int
    if TYPE_CHECKING:
        y: str

class B(NamedTuple):
    x: int
    if STATIC_FALSE:
        y: str

class C(NamedTuple):
    x: int
    if not TYPE_CHECKING:
        y: str

a = A(1, "hi")
reveal_type(a)  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.A]"
b = B(1)
reveal_type(b)  # N: Revealed type is "tuple[builtins.int, fallback=__main__.B]"
B(1, "extra")  # E: Too many arguments for "B"
c = C(1)
reveal_type(c)  # N: Revealed type is "tuple[builtins.int, fallback=__main__.C]"
C(1, "extra")  # E: Too many arguments for "C"
[builtins fixtures/tuple.pyi]

