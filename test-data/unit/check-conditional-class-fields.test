[case testConditionalNestedIfsAndElifResolved]
# flags: --python-version 3.12
import sys
from typing import NamedTuple, TYPE_CHECKING

class N(NamedTuple):
    x: int
    if TYPE_CHECKING:
        if sys.version_info >= (3, 12):
            y: str
        else:
            z: int

n = N(1, "hi")
reveal_type(n)  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.N]"
n.z  # E: "N" has no attribute "z"

class M(NamedTuple):
    a: int
    if sys.version_info >= (3, 13):
        first: str
    elif sys.version_info >= (3, 12):
        second: bool
    elif sys.version_info >= (3, 11):
        third: int

m = M(1, True)
reveal_type(m)  # N: Revealed type is "tuple[builtins.int, builtins.bool, fallback=__main__.M]"
[builtins fixtures/tuple.pyi]

[case testConditionalUnresolvableNamedTuple]
# flags: --show-error-codes
from typing import NamedTuple

def some_runtime_flag() -> bool: ...

class N(NamedTuple):
    x: int
    if some_runtime_flag():  # E: Conditional definition in NamedTuple body requires a statically-knowable condition  [conditional-class-body]
        y: str
    z: int

n = N(1, 2)
reveal_type(n)  # N: Revealed type is "tuple[builtins.int, builtins.int, fallback=__main__.N]"
[builtins fixtures/tuple.pyi]

