[case testConditionalNamedTupleSubclassInheritance]
# flags: --python-version 3.12
import sys
from typing import NamedTuple

class Parent(NamedTuple):
    x: int
    if sys.version_info >= (3, 12):
        y: str

class Child(Parent):
    def label(self) -> str:
        return self.y

c = Child(1, "hi")
reveal_type(c)  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.Child]"
reveal_type(c._replace(y="world"))  # N: Revealed type is "tuple[builtins.int, builtins.str, fallback=__main__.Child]"
reveal_type(c._asdict())  # N: Revealed type is "builtins.dict[builtins.str, Any]"
reveal_type(c.label())  # N: Revealed type is "builtins.str"
[builtins fixtures/tuple.pyi]

