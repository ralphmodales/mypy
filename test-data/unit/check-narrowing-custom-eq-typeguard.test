[case testNarrowingCustomEqTypeGuardBasic]
from typing import Any, Generic, TypeVar
from typing_extensions import TypeGuard

T = TypeVar("T")

class IsInstance(Generic[T]):
    def __init__(self, t: type[T]) -> None: pass
    def __eq__(self, other: Any) -> TypeGuard[T]: pass

def f(v: Any) -> None:
    if v == IsInstance(int):
        reveal_type(v)  # N: Revealed type is "builtins.int"
    else:
        reveal_type(v)  # N: Revealed type is "Any"
[builtins fixtures/primitives.pyi]

