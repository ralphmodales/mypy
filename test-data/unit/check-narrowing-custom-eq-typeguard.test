[case testNarrowingCustomEqOverloadedMatching]
from typing import Any, overload
from typing_extensions import TypeGuard

class Matching:
    @overload
    def __eq__(self, other: int) -> TypeGuard[int]: ...
    @overload
    def __eq__(self, other: Any) -> TypeGuard[int]: ...
    def __eq__(self, other: Any) -> Any: return True

def f(v: Any) -> None:
    if v == Matching():
        reveal_type(v)  # N: Revealed type is "builtins.int"
    else:
        reveal_type(v)  # N: Revealed type is "Any"
[builtins fixtures/primitives.pyi]

